    "@angular/common": "^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0",
    "@angular/core": "^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0",
    "@angular/forms": "^19.0.0 || ^20.0.0 || ^21.0.0 || ^22.0.0"
  },
  "dependencies": {
